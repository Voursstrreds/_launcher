[Unit]
Description=svc.service UNIT FILE
Requires=p1.service p2.service
PartOf=p1.service p2.service
After=p1.service p2.service
StartLimitIntervalSec=30
StartLimitBurst=5

[Service]
Type=simple
ExecStart=podman run --name svc docker.io/library/alpine:latest
ExecStop=podman stop svc
ExecStopPost=podman rm svc
RestartSec=2
Restart=on-failure

